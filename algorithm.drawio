        <mxCell id="ndEAR4yfymwzl2xwkQWQ-12" value="5. СОХРАНЕНИЕ ШАГА &quot;0&quot;&amp;nbsp;&lt;div&gt;Запись в simulation_steps Запись в machines_state&lt;/div&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#8064A2;strokeColor=#4A3866;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
