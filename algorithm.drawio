        <mxCell id="ndEAR4yfymwzl2xwkQWQ-13" value="6. ПРОВЕРКА ДЕЙСТВИЯ&lt;div&gt;Нажат шаг или автошаг?&lt;/div&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFC000;strokeColor=#9E6000;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
