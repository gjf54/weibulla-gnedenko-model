        <mxCell id="ndEAR4yfymwzl2xwkQWQ-15" value="8. ПРОВЕРКА ОТКАЗОВ&amp;nbsp;&lt;div&gt;Для каждого станка:&amp;nbsp;&lt;/div&gt;&lt;div&gt;remaining &amp;lt;= 0?&lt;/div&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFC000;strokeColor=#9E6000;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
