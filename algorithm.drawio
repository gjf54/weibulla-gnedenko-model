        </mxCell>
        <mxCell id="ndEAR4yfymwzl2xwkQWQ-16" value="9. ОБРАБОТКА ОТКАЗА&lt;div&gt;Статус → &#39;waiting&#39;&lt;/div&gt;&lt;div&gt;Генерация u_repair&lt;/div&gt;&lt;div&gt;Расчет repair_time&amp;nbsp;&lt;/div&gt;&lt;div&gt;Добавление в очередь&amp;nbsp;&lt;/div&gt;&lt;div&gt;Запись в machine_history&lt;/div&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#9BBB59;strokeColor=#6B8C23;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
