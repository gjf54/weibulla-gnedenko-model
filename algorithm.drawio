        <mxCell id="ndEAR4yfymwzl2xwkQWQ-17" value="10. СОРТИРОВКА ОЧЕРЕДИ&amp;nbsp;&lt;div&gt;По added_step (FIFO)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4F81BD;strokeColor=#2F5597;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
