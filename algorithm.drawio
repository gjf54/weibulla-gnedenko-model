        <mxCell id="ndEAR4yfymwzl2xwkQWQ-19" value="12. ПРОВЕРКА&lt;div&gt;ЗАВЕРШЕНИЯ&amp;nbsp;&lt;/div&gt;&lt;div&gt;repair_remaining &amp;lt;= 0?&lt;/div&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFC000;strokeColor=#9E6000;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
