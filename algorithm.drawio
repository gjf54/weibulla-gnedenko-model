        <mxCell id="ndEAR4yfymwzl2xwkQWQ-21" value="14. РАСЧЕТ ПРИБЫЛИ&lt;div&gt;Доход: working_count * r&lt;/div&gt;&lt;div&gt;Расходы: (machines-50)*30 + workers*3.75&lt;/div&gt;&lt;div&gt;Штраф: если machines&amp;lt;50 → machines*20&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4F81BD;strokeColor=#2F5597;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
