        <mxCell id="ndEAR4yfymwzl2xwkQWQ-9" value="2. ПРОВЕРКА СЕССИИ Существует активная сессия?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFC000;strokeColor=#9E6000;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
