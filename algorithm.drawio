        </mxCell>
        <mxCell id="ndEAR4yfymwzl2xwkQWQ-10" value="3. СОЗДАНИЕ НОВОЙ СЕССИИ&lt;div&gt;Генерация session_token&amp;nbsp;&lt;/div&gt;&lt;div&gt;Запись в simulation_sessions&amp;nbsp;&lt;/div&gt;&lt;div&gt;Сохранение параметров&lt;/div&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#9BBB59;strokeColor=#6B8C23;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1009" y="216" width="296" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ndEAR4yfymwzl2xwkQWQ-11" value="4. ГЕНЕРАЦИЯ СТАНКОВ&lt;div&gt;Расчет theta_work, theta_repair&lt;/div&gt;&lt;div&gt;Для каждого станка: генерация u_work, расчет total_lifetime, установка статуса &#39;working&#39;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4F81BD;strokeColor=#2F5597;fontColor=#000000;fontStyle=1;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="701" y="359" width="250" height="120" as="geometry" />
